@prefix ex:   <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

ex:alice   a foaf:Person, ex:Employee .
ex:bob     a foaf:Person, ex:Employee, ex:Manager .
ex:carol   a foaf:Person, ex:Manager .
ex:dave    a foaf:Person .
ex:eve     a ex:Employee .

ex:alice foaf:knows ex:bob .
ex:bob   foaf:knows ex:carol .
ex:carol foaf:knows ex:dave .
ex:dave  foaf:knows ex:eve .
ex:eve   foaf:knows ex:alice .
